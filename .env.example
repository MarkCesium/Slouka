# PostgreSQL container settings
POSTGRES_USER=backend
POSTGRES_PASSWORD=backendpassword123
POSTGRES_DB=backend

# Application settings (bot/.env, env_nested_delimiter="__")
DATABASE__URL=postgresql+asyncpg://backend:backendpassword123@database:5432/backend
TELEGRAM__TOKEN=your-telegram-bot-token
